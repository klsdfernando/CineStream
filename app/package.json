{
    "name": "cinestream",
    "version": "1.4.2",
    "description": "Cross-platform Movie Streaming Application",
    "author": {
        "name": "Sushan Fernando",
        "email": "klsdfernando@gmail.com"
    },
    "main": "main.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/klsdfernando/CineStream.git"
    },
    "scripts": {
        "start": "electron .",
        "dev": "electron . --enable-logging",
        "dist": "electron-builder"
    },
    "dependencies": {
        "webtorrent": "^2.8.5"
    },
    "devDependencies": {
        "electron": "^28.2.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.cinestream.desktop",
        "productName": "CineStream",
        "publish": [
            {
                "provider": "github",
                "owner": "klsdfernando",
                "repo": "CineStream"
            }
        ],
        "directories": {
            "output": "dist",
            "buildResources": "build"
        },
        "icon": "build/icon.png",
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Video",
            "icon": "build/icon.png"
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "category": "public.app-category.video",
            "icon": "build/icon.png"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "build/icon.png"
        }
    }
}