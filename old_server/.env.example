# ═══════════════════════════════════════════════════════
#  CineStream Server - Environment Configuration
#  Copy this file to .env and fill in your values:
#  cp .env.example .env
# ═══════════════════════════════════════════════════════

# Server Port (default: 3001)
PORT=3001

# Server Host (use 0.0.0.0 for VPS, localhost for local dev)
HOST=0.0.0.0

# TMDB API Key (required - get from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# JWT Secret for user auth tokens (use a long random string)
JWT_SECRET=

# Admin Password (default admin login: username=admin, password=admin123)
ADMIN_PASSWORD=admin123
